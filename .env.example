# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=recsys-ecommerce

# --- DVC remote (Azure Blob Storage) ---
# Read-only SAS token so evaluators can `dvc pull` without an Azure account.
AZURE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_STORAGE_SAS_TOKEN=<read-only-sas-token>

# --- Reproducibility ---
RANDOM_SEED=42
